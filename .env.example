# Example .env for Infinity Free / shared hosting
# Use the Supabase REST API (PostgREST) — recommended on shared hosting

USE_SUPABASE_API=1
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# Optional: only if you perform server-side writes via API (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Application settings
BASE_URL=/VEZZ

# DB vars are optional; left for local/dev setups
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
